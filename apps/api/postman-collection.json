    {
      "name": "Tags - Bulk Insert",
      "item": [
        {
          "name": "Create 50 Tags",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response has tag data', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('slug');",
                  "    pm.expect(jsonData).to.have.property('name');",
                  "    pm.collectionVariables.set('tagId', jsonData._id);",
                  "});",
                  "",
                  "// Continue creating more tags",
                  "const currentIteration = pm.collectionVariables.get('tagIteration') || 1;",
                  "if (currentIteration < 50) {",
                  "    pm.collectionVariables.set('tagIteration', currentIteration + 1);",
                  "    postman.setNextRequest('Create 50 Tags');",
                  "} else {",
                  "    pm.collectionVariables.set('tagIteration', 1);",
                  "    postman.setNextRequest(null);",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const iteration = pm.collectionVariables.get('tagIteration') || 1;",
                  "const categories = ['food', 'transport', 'entertainment', 'shopping', 'bills', 'salary', 'investment', 'health', 'education', 'travel'];",
                  "const adjectives = ['important', 'urgent', 'regular', 'monthly', 'weekly', 'annual', 'personal', 'business', 'recurring', 'one-time'];",
                  "const category = categories[iteration % categories.length];",
                  "const adjective = adjectives[Math.floor(iteration / categories.length) % adjectives.length];",
                  "const slug = `${adjective}-${category}-${iteration}`;",
                  "const name = `${adjective.charAt(0).toUpperCase() + adjective.slice(1)} ${category.charAt(0).toUpperCase() + category.slice(1)} ${iteration}`;",
                  "const colors = ['#FF6B6B', '#4ECDC4', '#45B7D1', '#FFA07A', '#98D8C8', '#F7DC6F', '#BB8FCE', '#85929E', '#F8B739', '#52BE80'];",
                  "pm.collectionVariables.set('currentTagSlug', slug);",
                  "pm.collectionVariables.set('currentTagName', name);",
                  "pm.collectionVariables.set('currentTagColor', colors[iteration % colors.length]);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"slug\": \"{{currentTagSlug}}\",\n  \"name\": \"{{currentTagName}}\",\n  \"description\": \"Tag created for testing - iteration {{tagIteration}}\",\n  \"color\": \"{{currentTagColor}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/tags",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tags"]
            }
          }
        }
      ]
    },
