        {
          "name": "Create 100 Transactions",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response has transaction data', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('amount');",
                  "    pm.collectionVariables.set('transactionId', jsonData._id);",
                  "});",
                  "",
                  "const currentIteration = pm.collectionVariables.get('transactionIteration') || 1;",
                  "if (currentIteration < 100) {",
                  "    pm.collectionVariables.set('transactionIteration', currentIteration + 1);",
                  "    postman.setNextRequest('Create 100 Transactions');",
                  "} else {",
                  "    pm.collectionVariables.set('transactionIteration', 1);",
                  "    postman.setNextRequest(null);",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const iteration = pm.collectionVariables.get('transactionIteration') || 1;",
                  "const states = ['sent', 'received'];",
                  "const indicators = ['Credit', 'Debit'];",
                  "const statuses = ['Booked', 'Pending'];",
                  "const stores = ['Walmart', 'Amazon', 'Target', 'Starbucks', 'McDonalds', 'Shell', 'Costco', 'Whole Foods', 'Apple Store', 'Best Buy'];",
                  "const locations = ['New York, NY', 'Los Angeles, CA', 'Chicago, IL', 'Houston, TX', 'Phoenix, AZ', 'Philadelphia, PA', 'San Antonio, TX', 'San Diego, CA'];",
                  "const currencies = ['USD', 'EUR', 'GBP'];",
                  "const state = states[iteration % 2];",
                  "const indicator = state === 'sent' ? 'Debit' : 'Credit';",
                  "const status = statuses[iteration % statuses.length];",
                  "const store = stores[iteration % stores.length];",
                  "const location = locations[iteration % locations.length];",
                  "const currency = currencies[iteration % currencies.length];",
                  "const amount = (Math.random() * 500 + 10).toFixed(2);",
                  "const daysAgo = Math.floor(Math.random() * 365);",
                  "const date = new Date();",
                  "date.setDate(date.getDate() - daysAgo);",
                  "pm.collectionVariables.set('currentTransactionState', state);",
                  "pm.collectionVariables.set('currentTransactionIndicator', indicator);",
                  "pm.collectionVariables.set('currentTransactionStatus', status);",
                  "pm.collectionVariables.set('currentTransactionStore', store);",
                  "pm.collectionVariables.set('currentTransactionLocation', location);",
                  "pm.collectionVariables.set('currentTransactionAmount', amount);",
                  "pm.collectionVariables.set('currentTransactionCurrency', currency);",
                  "pm.collectionVariables.set('currentTransactionDate', date.toISOString());"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{authToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accountId\": \"{{accountId}}\",\n  \"amount\": {\n    \"sum\": {{currentTransactionAmount}},\n    \"currency\": \"{{currentTransactionCurrency}}\"\n  },\n  \"notes\": \"Transaction {{transactionIteration}} at {{currentTransactionStore}}\",\n  \"state\": \"{{currentTransactionState}}\",\n  \"store\": \"{{currentTransactionStore}}\",\n  \"location\": \"{{currentTransactionLocation}}\",\n  \"creditDebitIndicator\": \"{{currentTransactionIndicator}}\",\n  \"status\": \"{{currentTransactionStatus}}\",\n  \"date\": \"{{currentTransactionDate}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/transactions",
              "host": ["{{baseUrl}}"],
              "path": ["api", "transactions"]
            }
          }
        }
      ]
    },
