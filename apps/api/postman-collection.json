              "listen": "prerequest",
              "script": {
                "exec": [
                  "const iteration = pm.collectionVariables.get('accountIteration') || 1;",
                  "const types = ['Personal', 'Business'];",
                  "const subTypes = ['CurrentAccount', 'Savings', 'CreditCard'];",
                  "const currencies = ['USD', 'EUR', 'GBP', 'JPY', 'CAD', 'AUD'];",
                  "const banks = ['Chase', 'Bank of America', 'Wells Fargo', 'Citibank', 'Capital One', 'US Bank', 'PNC', 'TD Bank'];",
                  "const accountTypes = ['Checking', 'Savings', 'Credit', 'Investment', 'Business'];",
                  "const type = types[iteration % types.length];",
                  "const subType = subTypes[iteration % subTypes.length];",
                  "const currency = currencies[iteration % currencies.length];",
                  "const bank = banks[iteration % banks.length];",
                  "const accountType = accountTypes[iteration % accountTypes.length];",
                  "const bankAccountId = `ACC${String(10000 + iteration).padStart(8, '0')}`;",
