                  "    postman.setNextRequest('Create 50 Receipts');",
                  "} else {",
                  "    pm.collectionVariables.set('receiptIteration', 1);",
                  "    postman.setNextRequest(null);",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const iteration = pm.collectionVariables.get('receiptIteration') || 1;",
                  "const stores = ['Walmart', 'Target', 'Whole Foods', 'Kroger', 'Safeway', 'Costco', 'CVS', 'Walgreens'];",
                  "const locations = ['123 Main St', '456 Oak Ave', '789 Elm Rd', '321 Pine Ln', '654 Maple Dr'];",
                  "const store = stores[iteration % stores.length];",
                  "const location = locations[iteration % locations.length];",
                  "const price = (Math.random() * 200 + 20).toFixed(2);",
                  "const daysAgo = Math.floor(Math.random() * 180);",
                  "const date = new Date();",
                  "date.setDate(date.getDate() - daysAgo);",
                  "pm.collectionVariables.set('currentReceiptStore', store);",
                  "pm.collectionVariables.set('currentReceiptLocation', location);",
                  "pm.collectionVariables.set('currentReceiptPrice', price);",
                  "pm.collectionVariables.set('currentReceiptDate', date.toISOString());"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{authToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transactionId\": \"{{transactionId}}\",\n  \"price\": {{currentReceiptPrice}},\n  \"store\": \"{{currentReceiptStore}}\",\n  \"location\": \"{{currentReceiptLocation}}\",\n  \"date\": \"{{currentReceiptDate}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/receipts",
              "host": ["{{baseUrl}}"],
              "path": ["api", "receipts"]
            }
          }
        }
