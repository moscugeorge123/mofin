              "listen": "prerequest",
              "script": {
                "exec": [
                  "const iteration = pm.collectionVariables.get('receiptProductIteration') || 1;",
                  "const productIds = JSON.parse(pm.collectionVariables.get('allProductIds') || '[]');",
                  "const productId = productIds[iteration % productIds.length];",
                  "const productNames = ['Milk', 'Bread', 'Eggs', 'Butter', 'Cheese', 'Chicken', 'Rice', 'Pasta'];",
                  "const quantityTypes = ['KG', 'G', 'L', 'ML', 'PCS', 'BUC', 'UNIT', 'BOX', 'PACK'];",
                  "const name = productNames[iteration % productNames.length] + ' #' + iteration;",
                  "const price = (Math.random() * 20 + 2).toFixed(2);",
                  "const quantity = (Math.random() * 5 + 0.5).toFixed(2);",
                  "const quantityType = quantityTypes[iteration % quantityTypes.length];",
                  "const discount = Math.random() > 0.7 ? (Math.random() * 20).toFixed(0) : 0;",
                  "pm.collectionVariables.set('currentProductId', productId);",
                  "pm.collectionVariables.set('currentReceiptProductName', name);",
                  "pm.collectionVariables.set('currentReceiptProductPrice', price);",
                  "pm.collectionVariables.set('currentReceiptProductQuantity', quantity);",
                  "pm.collectionVariables.set('currentReceiptProductQuantityType', quantityType);",
                  "pm.collectionVariables.set('currentReceiptProductDiscount', discount);"
                ],
